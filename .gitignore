
# Ignore Python cache and metadata
__pycache__/
.pytest_cache/
*.py[cod]
*.pyo
*.pyd
*.pkl

# Ignore logs
*.log

# Ignore Jupyter/IPython history
.ipynb_checkpoints/

# Ignore numpy and model artifacts
*.npy
*.npz

# Ignore temporary and backup files
*~
*.bak
.DS_Store

# Ignore generated pipeline outputs
artifacts/

# Allow configuration and data files
!config.py
!source_data/

# Environments
.vscode/
.venv/
.env

# Local data and outputs
data/*
results/*
logs/*

# Keep folders empty
!data/.gitkeep
!results/.gitkeep
!logs/.gitkeep

# Distribution and build files
dist/
*.egg-info/
build/
__pycache__/
*.pyc
.pytest_tmp/
.pytest_cache/
tests_output.txt